# 기상청 공공데이터포털 일반 인증키 (decoded)
KMA_SERVICE_KEY=your-decoded-service-key-here

# 서울랜드 격자 좌표 (과천)
SEOULLAND_NX=60
SEOULLAND_NY=120

# 학습된 XGBoost 모델 (joblib.dump 형식)
MODEL_PATH=artifacts/crowd_model.pkl
# 회귀 예측값 → 혼잡도 등급 변환 임계치 (일일 입장객 수 기준)
CROWD_LOW_MAX=2500
CROWD_MID_MAX=5500

# Firebase Admin SDK 서비스 계정 JSON 경로
FIREBASE_CREDENTIALS_PATH=secrets/firebase-admin.json
FCM_TOPIC=all_users

# 스케줄러 설정
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_ENABLED=1
