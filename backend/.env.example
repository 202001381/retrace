# 백엔드 환경변수 템플릿.
# 사용법:
#   1. 이 파일을 .env 로 복사 (cp .env.example .env)
#   2. 각 값을 본인 키로 채움
#   3. .env 는 .gitignore 로 차단되어 commit 안 됨
#
# PowerShell 환경변수로 주입할 때는 $env:VAR_NAME = '값' 형태로 사용.

# ── 필수 ──

# 기상청 단기예보 서비스키 (Decoding)
# 발급: https://www.data.go.kr → "기상청 단기예보 ((구) 동네예보) 조회서비스" 활용신청
# 형식: 약 88자, +, /, = 포함 가능
KMA_API_KEY=

# Firebase / GCP 프로젝트 ID (문자열, 번호 X)
GCP_PROJECT_ID=seoul-land-dev

# Firebase 서비스 계정 키 JSON 경로
# 발급: https://console.firebase.google.com → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# 본인 노트북 어딘가에 안전하게 저장 후 절대경로 지정
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\YourName\.gcp\firebase-sa.json

# ── 선택 ──

# Anthropic Claude API 키 (없으면 /api/story 가 스텁 응답 반환)
# 발급: https://console.anthropic.com → API Keys → Create Key (결제 등록 필요)
ANTHROPIC_API_KEY=

# 기상청 격자 좌표 (서울랜드 인근 기본값)
KMA_NX=62
KMA_NY=122

# FCM 발송 모드. true 면 실제 디바이스에 안 보내고 검증만 (개발 권장)
FCM_DRY_RUN=true

# 데이터 백엔드. firestore (운영 기본) 또는 mock (오프라인 테스트)
DATA_BACKEND=firestore

# 인증 강제 여부. true 면 모든 /api/* 에 Firebase ID Token 필수
# 프론트엔드가 토큰 부착 전이면 false 유지 (호환성)
AUTH_REQUIRED=false

# 내부 잡 (/internal/jobs/*) 보호 토큰
# 로컬 개발에서는 미설정 가능. 운영(Cloud Run)에선 Secret Manager 에 등록.
INTERNAL_JOB_TOKEN=

# 시간대
TIMEZONE=Asia/Seoul

# XGBoost 모델 경로 (기본값 그대로 두면 됨)
XGBOOST_MODEL_PATH=./models/visit_value.json
